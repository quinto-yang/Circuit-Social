# 复制为仓库根目录的 `.env` 后，`docker compose` 会自动加载并用于变量替换。
# cp .env.docker.example .env

# 浏览器访问前端地址（需与 CORS / Cookie 一致）
WEB_ORIGIN=http://localhost:3000

# 浏览器请求 API 的根地址（前端请求会自动拼接 /api）
NEXT_PUBLIC_API_ORIGIN=http://localhost:4000

# 宿主机映射端口
WEB_HOST_PORT=3000
API_HOST_PORT=4000

# Postgres（与下方 DATABASE_URL 中的账号密码一致）
POSTGRES_DB=circuit_social
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# API / db-init 使用的连接串（默认连 compose 内的 postgres 服务名）
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/circuit_social

# API 监听地址（Docker 内需 0.0.0.0 以便端口映射；一般无需改）
# LISTEN_HOST=0.0.0.0
