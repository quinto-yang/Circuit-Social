generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int                  @id @default(autoincrement())
  nickname          String
  bio               String               @default("")
  avatarUrl         String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  wallets           WalletAccount[]
  sessions          Session[]
  sentRequests      FriendRequest[]      @relation("sentRequests")
  receivedReqs      FriendRequest[]      @relation("receivedRequests")
  memberships       ConversationMember[]
  messages          Message[]
  moments           Moment[]
  momentLikes       MomentLike[]
  momentComments    MomentComment[]
  commentLikes      MomentCommentLike[]
  pinnedComments    MomentCommentPin[]   @relation("PinnedByUser")
  notifications     Notification[]       @relation("NotificationsForUser")
  notificationsByMe Notification[]       @relation("NotificationsByActor")
  uploads           Upload[]
  reports           Report[]
  pointLedger       PointLedger[]
  taskProgress      TaskProgress[]
}

model Notification {
  id        Int       @id @default(autoincrement())
  userId    Int
  actorId   Int
  kind      String
  momentId  Int?
  commentId Int?
  extra     Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user    User           @relation("NotificationsForUser", fields: [userId], references: [id], onDelete: Cascade)
  actor   User           @relation("NotificationsByActor", fields: [actorId], references: [id], onDelete: Cascade)
  moment  Moment?        @relation(fields: [momentId], references: [id], onDelete: Cascade)
  comment MomentComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([momentId, createdAt])
  @@index([commentId, createdAt])
}

model WalletAccount {
  id         Int      @id @default(autoincrement())
  userId     Int
  chainId    Int
  chainLabel String
  address    String
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chainId, address])
}

model Session {
  id        String   @id
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FriendRequest {
  id         Int      @id @default(autoincrement())
  fromUserId Int
  toUserId   Int
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  fromUser   User     @relation("sentRequests", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser     User     @relation("receivedRequests", fields: [toUserId], references: [id], onDelete: Cascade)
}

model Friendship {
  id         Int      @id @default(autoincrement())
  userLowId  Int
  userHighId Int
  createdAt  DateTime @default(now())

  @@unique([userLowId, userHighId])
}

model Conversation {
  id         Int                  @id @default(autoincrement())
  kind       String
  title      String
  inviteCode String?              @unique
  ownerId    Int?
  createdAt  DateTime             @default(now())
  members    ConversationMember[]
  messages   Message[]
}

model ConversationMember {
  id                Int          @id @default(autoincrement())
  conversationId    Int
  userId            Int
  role              String       @default("member")
  lastReadMessageId Int?
  mutedUntil        DateTime?
  joinedAt          DateTime     @default(now())
  conversation      Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             Int              @id @default(autoincrement())
  conversationId Int
  senderId       Int
  content        String
  createdAt      DateTime         @default(now())
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User             @relation(fields: [senderId], references: [id], onDelete: Cascade)
  mentions       MessageMention[]
}

model MessageMention {
  id        Int     @id @default(autoincrement())
  messageId Int
  userId    Int
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

model Moment {
  id            Int               @id @default(autoincrement())
  authorId      Int
  content       String
  createdAt     DateTime          @default(now())
  author        User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  images        MomentImage[]
  comments      MomentComment[]
  likes         MomentLike[]
  pinnedComment MomentCommentPin?
  notifications Notification[]

  @@index([authorId, createdAt])
}

model MomentLike {
  id        Int      @id @default(autoincrement())
  momentId  Int
  userId    Int
  createdAt DateTime @default(now())
  moment    Moment   @relation(fields: [momentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([momentId, userId])
  @@index([userId, createdAt])
}

model MomentComment {
  id              Int                 @id @default(autoincrement())
  momentId        Int
  authorId        Int
  content         String
  parentCommentId Int?
  createdAt       DateTime            @default(now())
  moment          Moment              @relation(fields: [momentId], references: [id], onDelete: Cascade)
  author          User                @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent          MomentComment?      @relation("MomentCommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies         MomentComment[]     @relation("MomentCommentReplies")
  likes           MomentCommentLike[]
  pinnedIn        MomentCommentPin?
  notifications   Notification[]

  @@index([momentId, createdAt])
  @@index([authorId, createdAt])
  @@index([parentCommentId])
}

model MomentCommentLike {
  id        Int           @id @default(autoincrement())
  commentId Int
  userId    Int
  createdAt DateTime      @default(now())
  comment   MomentComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId, createdAt])
}

model MomentCommentPin {
  id             Int           @id @default(autoincrement())
  momentId       Int           @unique
  commentId      Int           @unique
  pinnedByUserId Int
  pinnedAt       DateTime      @default(now())
  moment         Moment        @relation(fields: [momentId], references: [id], onDelete: Cascade)
  comment        MomentComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  pinnedBy       User          @relation("PinnedByUser", fields: [pinnedByUserId], references: [id], onDelete: Cascade)

  @@index([pinnedByUserId, pinnedAt])
}

model MomentImage {
  id       Int    @id @default(autoincrement())
  momentId Int
  uploadId Int
  moment   Moment @relation(fields: [momentId], references: [id], onDelete: Cascade)
  upload   Upload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@unique([momentId, uploadId])
}

model Upload {
  id         Int           @id @default(autoincrement())
  userId     Int
  url        String
  fileName   String
  mimeType   String
  size       Int
  createdAt  DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  momentRefs MomentImage[]
}

model Report {
  id         Int      @id @default(autoincrement())
  reporterId Int
  kind       String
  targetId   Int
  reason     String
  createdAt  DateTime @default(now())
  reporter   User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  actorId    Int?
  action     String
  targetType String
  targetId   String
  detail     String?
  createdAt  DateTime @default(now())
}

model PointLedger {
  id        Int      @id @default(autoincrement())
  userId    Int
  delta     Int
  reason    String
  refType   String?
  refId     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, reason, refType, refId])
  @@index([userId, createdAt])
  @@index([refType, refId])
}

model TaskDefinition {
  key           String         @id
  titleZh       String
  titleEn       String
  descriptionZh String
  descriptionEn String
  target        Int            @default(1)
  points        Int            @default(0)
  enabled       Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  progresses    TaskProgress[]
}

model TaskProgress {
  id          Int            @id @default(autoincrement())
  userId      Int
  taskKey     String
  progress    Int            @default(0)
  completedAt DateTime?
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  task        TaskDefinition @relation(fields: [taskKey], references: [key], onDelete: Cascade)

  @@unique([userId, taskKey])
  @@index([userId, updatedAt])
}

model TenantApp {
  id          Int             @id @default(autoincrement())
  ownerUserId Int
  name        String
  chainPolicy String[]
  callbackUrl String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  domains     TenantDomain[]
  keys        TenantKey[]
  branding    TenantBranding?
}

model TenantDomain {
  id        Int       @id @default(autoincrement())
  appId     Int
  domain    String
  createdAt DateTime  @default(now())
  app       TenantApp @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([appId, domain])
}

model TenantKey {
  id            Int       @id @default(autoincrement())
  appId         Int
  keyId         String
  status        String    @default("active")
  lastRotatedAt DateTime?
  createdAt     DateTime  @default(now())
  app           TenantApp @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([appId, keyId])
}

model TenantBranding {
  id          Int       @id @default(autoincrement())
  appId       Int       @unique
  logoUrl     String?
  themeColor  String?
  displayName String?
  updatedAt   DateTime  @updatedAt
  app         TenantApp @relation(fields: [appId], references: [id], onDelete: Cascade)
}

model SiteSettings {
  id        Int      @id @default(1)
  data      Json
  updatedAt DateTime @updatedAt
}
