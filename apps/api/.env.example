PORT=4000
WEB_ORIGIN=http://127.0.0.1:3000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/circuit_social
REDIS_URL=redis://localhost:6379

# 站点公开配置初始值（内存模式；运行中可由 POST /api/admin/site-settings 覆盖，重启后从此处重新加载）
ENABLE_SOLANA_LOGIN=false
ADS_ENABLED=false
APP_PUBLIC_NAME=

# 管理后台密钥（与 Web /admin 页输入的 Bearer 一致；留空时默认密钥为 123，建议首次登录后立即轮换）
ADMIN_TOKEN=
